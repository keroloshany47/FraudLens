      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "P90CE95BFBC655DDE"
          },
          "rawSql": "SELECT txn_date AS time, ROUND(SUM(fraud_count)::numeric / NULLIF(SUM(total_transactions),0) * 100, 4) AS fraud_rate_pct FROM fraudlens_dw.mart_fraud_summary GROUP BY txn_date ORDER BY txn_date;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "postgres",
        "uid": "P90CE95BFBC655DDE"
      }
    },
