# =============================================================
# FraudLens — .gitattributes
# =============================================================

# -------------------------------------------------------------
# DEFAULT: enforce LF line endings for all text files
# (ensures consistency across macOS / Windows / Linux / Docker)
# -------------------------------------------------------------
* text=auto eol=lf

# -------------------------------------------------------------
# SHELL & SCRIPTS
# Must stay LF — shells break on CRLF
# -------------------------------------------------------------
*.sh            text eol=lf
*.bash          text eol=lf
Makefile        text eol=lf

# -------------------------------------------------------------
# PYTHON
# -------------------------------------------------------------
*.py            text eol=lf diff=python

# -------------------------------------------------------------
# SQL & dbt
# -------------------------------------------------------------
*.sql           text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf

# -------------------------------------------------------------
# CONFIG & DOCS
# -------------------------------------------------------------
*.md            text eol=lf diff=markdown
*.txt           text eol=lf
*.env           text eol=lf
*.env.example   text eol=lf
*.toml          text eol=lf
*.cfg           text eol=lf
*.ini           text eol=lf
*.conf          text eol=lf
*.properties    text eol=lf

# -------------------------------------------------------------
# DOCKER
# -------------------------------------------------------------
Dockerfile      text eol=lf
Dockerfile.*    text eol=lf

# -------------------------------------------------------------
# JSON (Grafana dashboards, package configs, etc.)
# -------------------------------------------------------------
*.json          text eol=lf

# -------------------------------------------------------------
# REQUIREMENTS & LOCK FILES — ours, don't touch on merge
# -------------------------------------------------------------
requirements*.txt        text eol=lf merge=ours
package-lock.json        text eol=lf merge=ours
dbt/package-lock.yml     text eol=lf merge=ours

# -------------------------------------------------------------
# BINARY — never diff or merge
# -------------------------------------------------------------
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.gz     binary
*.tar    binary
*.parquet binary
*.jar    binary
*.class  binary
*.pyc    binary

# -------------------------------------------------------------
# DATA FILES — treated as binary (no diffs, no CRLF conversion)
# -------------------------------------------------------------
*.csv    binary
*.tsv    binary

# =============================================================
# GITHUB LINGUIST — language detection & repo stats
# =============================================================

# --- Force-detect core languages ---
*.sql           linguist-detectable=true  linguist-language=SQL
*.py            linguist-detectable=true
*.sh            linguist-detectable=true  linguist-language=Shell

# --- dbt model paths ---
dbt/models/**/*.sql     linguist-detectable=true  linguist-language=SQL
dbt/macros/**/*.sql     linguist-detectable=true  linguist-language=SQL

# --- Airflow DAGs ---
airflow/dags/**/*.py    linguist-detectable=true

# --- Spark jobs ---
spark/jobs/**/*.py      linguist-detectable=true
spark/tests/**/*.py     linguist-detectable=true

# --- Kafka producer ---
kafka/producer/**/*.py  linguist-detectable=true

# --- Infrastructure configs ---
docker-compose*.yml     linguist-language=YAML
dbt/dbt_project.yml     linguist-language=YAML
dbt/packages.yml        linguist-language=YAML
dbt/profiles.yml        linguist-language=YAML

# --- Grafana dashboards: detectable but not inflating JSON stats ---
monitoring/grafana/provisioning/dashboards/*.json  linguist-detectable=true

# --- Prometheus config ---
monitoring/prometheus/*.yml  linguist-language=YAML

# =============================================================
# LINGUIST — exclude generated / vendored / data files
# =============================================================

# dbt compiled output
dbt/target/**           linguist-generated=true
dbt/dbt_packages/**     linguist-vendored=true

# Airflow logs
airflow/logs/**         linguist-generated=true

# Spark checkpoints
spark/checkpoints/**    linguist-generated=true

# Python cache
**/__pycache__/**       linguist-generated=true
**/*.pyc                linguist-generated=true

# Data files
data/**                 linguist-generated=true

# Virtual environments
.venv/**                linguist-vendored=true
venv/**                 linguist-vendored=true
